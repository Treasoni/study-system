# === 系统文件 ===
.DS_Store
*.log

# === 依赖 ===
node_modules/
package-lock.json
skills-lock.json

# === 开发流程产物（用户不需要） ===
openspec/changes/              # 进行中的 change 提案
openspec/changes/archive/      # 已归档的 change 历史
.comet/                        # Comet 运行时状态
.codegraph/                    # CodeGraph 自动生成的索引数据库
docs/superpowers/              # 开发流程产生的 plans/specs/reports

# === 本地配置 ===
.claude/settings.local.json

# === 用户学习数据（可选共享） ===
.learnings/LEARNINGS.md
.learnings/ERRORS.md
.learnings/archive/
